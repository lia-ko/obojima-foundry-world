<section class="oa-band oa-card">
  <img class="oa-band-avatar oa-portrait" src="{{identity.img}}" alt="{{identity.name}}" {{#if editable}}data-action="editImage"{{/if}}>

  <div class="oa-topright">
    <div class="oa-inforow">
      <div class="oa-idtext">
        {{#if editable}}
          <input type="text" class="oa-inline-text oa-band-name" name="name" value="{{identity.name}}">
        {{else}}
          <div class="oa-band-name">{{identity.name}}</div>
        {{/if}}
        <div class="oa-band-sub">{{identity.subline}}</div>
        <div class="oa-band-cls">
          {{#if editable}}
            <select class="oa-inline-select oa-cls-sel" data-oa-detail="className">
              <option value="">— class —</option>
              {{#each classOptions}}<option value="{{this.key}}" {{#if (oa-eq this.key ../system.details.className)}}selected{{/if}}>{{this.label}}</option>{{/each}}
            </select>
            {{#if subclassOptions.length}}
            <select class="oa-inline-select oa-cls-sel" data-oa-detail="subclass">
              <option value="">— subclass —</option>
              {{#each subclassOptions}}<option value="{{this.key}}" {{#if (oa-eq this.key ../system.details.subclass)}}selected{{/if}}>{{this.label}}</option>{{/each}}
            </select>
            {{/if}}
            <span class="oa-muted oa-lv-badge">Lv {{system.details.level}}</span>
          {{else}}
            {{#if identity.className}}<b>{{identity.className}}{{#if identity.level}} {{identity.level}}{{/if}}</b>{{#if identity.subclass}} · {{identity.subclass}}{{/if}}{{else}}<span class="oa-muted">No class yet — click <b>Edit</b> to build your character</span>{{/if}}
          {{/if}}
        </div>
        {{#if identity.oaka}}<span class="oa-oaka">✦ {{identity.oaka}}</span>{{/if}}
        {{#if editable}}
          <button type="button" class="oa-levelup-btn {{#if build.needsSetup}}oa-build-cta{{/if}}" data-action="levelUp" {{#unless build.canBuild}}disabled{{/unless}}>{{build.label}}</button>
          {{#if build.needsSetup}}<div class="oa-build-hint">Fills in your saves, skills, HP, spell slots &amp; starting gear — you'll be asked a few quick choices.</div>{{/if}}
          <button type="button" class="oa-mini-btn" data-action="genAbilities">Set Ability Scores</button>
        {{/if}}
      </div>

      <div class="oa-hero">
        <div class="oa-hp">
          <div class="oa-hp-top">
            <span class="oa-hp-lab">Hit Points</span>
            {{#if editable}}
              <span class="oa-hp-tempedit">temp <input type="number" class="oa-stat-input" name="system.attributes.hp.temp" value="{{core.hp.temp}}"></span>
            {{else if core.hp.temp}}
              <span class="oa-hp-temp">+{{core.hp.temp}} temp</span>
            {{/if}}
          </div>
          {{#if editable}}
            <div class="oa-hp-edit">
              <input type="number" class="oa-stat-input" name="system.attributes.hp.value" value="{{core.hp.value}}">
              <span>/</span>
              <input type="number" class="oa-stat-input" name="system.attributes.hp.max" value="{{core.hp.max}}">
            </div>
          {{else}}
            <div class="oa-hp-big">{{core.hp.value}}<span> / {{core.hp.max}}</span></div>
            <div class="oa-hp-bar"><i style="width:{{core.hpPct}}%"></i>{{#if core.hp.temp}}<u style="width:{{core.hpTempPct}}%"></u>{{/if}}</div>
            <div class="oa-hp-adj">
              <button type="button" class="oa-hp-btn oa-hp-dmg" data-action="hpDamage">− Damage</button>
              <button type="button" class="oa-hp-btn oa-hp-heal" data-action="hpHeal">＋ Heal</button>
            </div>
          {{/if}}
        </div>

        <div class="oa-vitals">
          <div class="oa-tile oa-tile-ac">
            <span class="oa-tile-k">AC</span>
            {{#if editable}}<input type="number" class="oa-stat-input" name="system.attributes.ac" value="{{system.attributes.ac}}">{{else}}<span class="oa-tile-v">{{core.ac}}</span>{{/if}}
          </div>
          <div class="oa-tile oa-roll" data-action="roll" data-roll-type="initiative" data-tooltip="Roll initiative">
            <span class="oa-tile-k">Init</span><span class="oa-tile-v">{{core.init}}</span>
          </div>
          <div class="oa-tile">
            <span class="oa-tile-k">Speed</span>
            {{#if editable}}<input type="number" class="oa-stat-input" name="system.attributes.speed" value="{{system.attributes.speed}}">{{else}}<span class="oa-tile-v">{{core.speed}}</span>{{/if}}
          </div>
          <div class="oa-tile">
            <span class="oa-tile-k">Prof</span>
            {{#if editable}}<input type="number" class="oa-stat-input" name="system.attributes.prof" value="{{system.attributes.prof}}">{{else}}<span class="oa-tile-v">{{oa-signed core.prof}}</span>{{/if}}
          </div>
        </div>
      </div>
    </div>

    <div class="oa-abil">
      {{#each abilities}}
      <div class="oa-ability {{#if this.saveProficient}}is-prof{{/if}}">
        <div class="oa-ability-top">
          <span class="oa-ability-abbr">{{this.label}}{{#if ../editable}}<i class="oa-save-toggle {{#if this.saveProficient}}on{{/if}}" data-action="toggleSaveProf" data-key="{{this.key}}" data-tooltip="Toggle save proficiency"></i>{{/if}}</span>
          {{#if ../editable}}<input type="number" class="oa-ability-input" name="system.abilities.{{this.key}}.value" value="{{this.value}}">{{else}}<span class="oa-ability-score">{{this.value}}</span>{{/if}}
        </div>
        <button type="button" class="oa-ability-check oa-roll" data-action="roll" data-roll-type="ability" data-key="{{this.key}}" data-tooltip="{{this.label}} check"><small>Check</small>{{this.mod}}</button>
        <button type="button" class="oa-ability-save oa-roll" data-action="roll" data-roll-type="save" data-key="{{this.key}}" data-tooltip="{{this.label}} save"><span class="oa-save-t">Save</span>{{this.save}}</button>
      </div>
      {{/each}}
    </div>
  </div>
</section>
